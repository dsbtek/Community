# ===========================================
# DEPLOYMENT ENVIRONMENT VARIABLES
# ===========================================
# Copy this file and set these variables in your deployment platform

# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# ===========================================

# Django Settings (REQUIRED)
SECRET_KEY=your-super-long-and-secure-secret-key-here-make-it-at-least-50-characters
DEBUG=0
ALLOWED_HOSTS=your-backend-domain.com,your-backend.platform.app

# Database (Choose ONE)
# For PostgreSQL (Recommended for production)
DATABASE_URL=postgresql://username:password@host:port/database_name

# OR for MySQL (if using Docker/custom setup)
# DB_HOST=your-mysql-host
# DB_NAME=community_db
# DB_USER=community_user
# DB_PASSWORD=your-secure-password
# DB_PORT=3306

# Frontend URL (REQUIRED for CORS)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Email Settings (OPTIONAL)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ===========================================
# FRONTEND ENVIRONMENT VARIABLES
# ===========================================

# API URL (REQUIRED)
REACT_APP_API_URL=https://your-backend-domain.com/api

# ===========================================
# PLATFORM-SPECIFIC EXAMPLES
# ===========================================

# RAILWAY BACKEND:
# SECRET_KEY=your-secret-key
# DEBUG=0
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_HOSTS=your-app.railway.app

# RENDER BACKEND:
# SECRET_KEY=your-secret-key
# DEBUG=0
# DATABASE_URL=postgresql://user:pass@host/db
# FRONTEND_URL=https://your-app.netlify.app
# ALLOWED_HOSTS=your-app.onrender.com

# HEROKU BACKEND:
# SECRET_KEY=your-secret-key
# DEBUG=0
# DATABASE_URL=postgres://user:pass@host/db (auto-provided)
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_HOSTS=your-app.herokuapp.com

# VERCEL FRONTEND:
# REACT_APP_API_URL=https://your-backend.railway.app/api

# NETLIFY FRONTEND:
# REACT_APP_API_URL=https://your-backend.onrender.com/api

# ===========================================
# SECURITY NOTES
# ===========================================
# 1. Never commit real environment variables to git
# 2. Use strong, unique passwords for databases
# 3. Generate a new SECRET_KEY for each deployment
# 4. Set DEBUG=0 for production
# 5. Only include your actual frontend domain in FRONTEND_URL
