{
  "name": "community-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Community Platform - Full Stack Application",
  "scripts": {
    "install": "npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt && pip install -r requirements-dev.txt",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "pytest",
    "test:watch": "concurrently \"npm run test:watch:frontend\" \"npm run test:watch:backend\"",
    "test:watch:frontend": "cd frontend && npm run test:watch",
    "test:watch:backend": "pytest --looponfail backend",
    "test:ci": "npm run test:ci:frontend && npm run test:ci:backend",
    "test:ci:frontend": "cd frontend && npm run test:ci",
    "test:ci:backend": "pytest --maxfail=1 --tb=short",
    "test:coverage": "npm run test:coverage:frontend && npm run test:coverage:backend",
    "test:coverage:frontend": "cd frontend && npm run test:coverage",
    "test:coverage:backend": "pytest --cov-report=html --cov-report=term",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm start",
    "dev:backend": "cd backend && python manage.py runserver",
    "build": "cd frontend && npm run build",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npx eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:backend": "cd backend && flake8 . && black --check . && isort --check-only .",
    "lint:fix": "npm run lint:fix:frontend && npm run lint:fix:backend",
    "lint:fix:frontend": "cd frontend && npx eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "lint:fix:backend": "cd backend && black . && isort .",
    "type-check": "cd frontend && npx tsc --noEmit",
    "type-check:backend": "cd backend && mypy .",
    "clean": "npm run clean:frontend && npm run clean:backend",
    "clean:frontend": "cd frontend && rm -rf build node_modules",
    "clean:backend": "find backend -name '*.pyc' -delete && find backend -name '__pycache__' -delete"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
